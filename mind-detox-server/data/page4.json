        { "id": "acidity_days_per_month", "label": "Acidity days/month (0–30)", "type": "number", "required": true, "min": 0, "max": 30 },
        { "id": "bloating_days_per_month", "label": "Bloating days/month (0–30)", "type": "number", "required": true, "min": 0, "max": 30 },
        { "id": "stomach_pain_days_per_month", "label": "Stomach pain days/month (0–30)", "type": "number", "required": true, "min": 0, "max": 30 }
